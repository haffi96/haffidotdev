{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "haffi-job-agent",
  "account_id": "7b90172cb4dfa9ecd9b6582bce068917",
  "main": "@tanstack/react-start/server-entry",
  "compatibility_date": "2026-05-24",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "jobs.haffi.dev",
      "custom_domain": true
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "haffi-job-agent",
      "database_id": "67040086-884b-4863-a7e4-8aa1444843b7"
    }
  ],
  "r2_buckets": [
    {
      "binding": "DOCUMENTS",
      "bucket_name": "haffi-job-agent-documents"
    }
  ],
  "secrets": {
    "required": [
      "BETTER_AUTH_SECRET",
      "BETTER_AUTH_URL",
      "GOOGLE_CLIENT_ID",
      "GOOGLE_CLIENT_SECRET",
      "OPENAI_API_KEY"
    ]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "invocation_logs": true
    }
  }
}
